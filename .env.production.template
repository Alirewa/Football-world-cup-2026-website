# Production Environment Template
# Copy to .env on the VPS and fill in all <placeholder> values.
# NEVER commit this file with real values.
#
# Generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# Generate AES-256 encryption key (32 bytes → 64 hex chars):
#   openssl rand -hex 32

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://football.ir
NEXT_PUBLIC_APP_NAME_FA=پیش‌بینی جام جهانی ۲۰۲۶
NEXT_PUBLIC_APP_NAME_EN=WC 2026 Prediction
NEXT_PUBLIC_TURNSTILE_SITE_KEY=<cloudflare-turnstile-site-key>

# ── Auth secrets ─────────────────────────────────────────────────
# RS256: private key signs tokens, public key verifies.
# Newlines must be escaped as \n for Docker env injection.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<base64-encoded-key>\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<base64-encoded-key>\n-----END PUBLIC KEY-----"

# AES-256-GCM key for encrypting national IDs at rest (64 hex chars = 32 bytes)
NATIONAL_ID_ENCRYPTION_KEY=<openssl-rand-hex-32-output>

# ── Database ─────────────────────────────────────────────────────
POSTGRES_DB=football
POSTGRES_USER=football
POSTGRES_PASSWORD=<strong-random-password-min-32-chars>
# Next.js connects via PgBouncer (connection_limit=1 required for transaction pooling)
DATABASE_URL=postgresql://football:<password>@pgbouncer:6432/football?pgbouncer=true&connection_limit=1

# ── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=<strong-random-password-min-32-chars>
REDIS_SENTINEL_HOSTS=redis-sentinel-1:26379
REDIS_SENTINEL_NAME=mymaster

# ── Storage (Arvan Cloud Object Storage) ─────────────────────────
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_ENDPOINT_HOSTNAME=s3.ir-thr-at1.arvanstorage.ir
S3_REGION=ir-thr-at1
S3_ACCESS_KEY=<arvan-access-key>
S3_SECRET_KEY=<arvan-secret-key>
S3_BUCKET=football-assets
S3_URL_EXPIRY=900

# ── SMS (Kaveh Negar) ────────────────────────────────────────────
KAVEH_NEGAR_API_KEY=<kaveh-negar-api-key>
KAVEH_NEGAR_SENDER=<kaveh-negar-sender-number>
KAVEH_NEGAR_TEMPLATE_OTP=<kaveh-negar-otp-template-name>
KAVEH_NEGAR_WEBHOOK_SECRET=<random-hmac-secret>

# ── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=mail.football.ir
SMTP_PORT=587
SMTP_USER=noreply@football.ir
SMTP_PASS=<smtp-password>
SMTP_FROM="جام جهانی ۲۰۲۶ <noreply@football.ir>"

# ── Cloudflare Turnstile ─────────────────────────────────────────
TURNSTILE_SECRET_KEY=<cloudflare-turnstile-secret-key>

# ── OTP Rate Limiting ────────────────────────────────────────────
OTP_MAX_PER_MOBILE_PER_15MIN=5
OTP_LOCKOUT_MAX_FAILURES_PER_HOUR=5
OTP_LOCKOUT_DURATION_SECONDS=3600
OTP_SESSION_EXPIRY_SECONDS=120
OTP_MAX_ATTEMPTS_PER_SESSION=3

# ── Docker / CI ──────────────────────────────────────────────────
GITHUB_ORG=your-github-org
IMAGE_TAG=latest

# ── Monitoring ───────────────────────────────────────────────────
ALERT_MOBILE=09120000000
SSL_DOMAIN=football.ir
