# =====================================================
# World Cup 2026 Prediction Platform — Environment
# Copy to .env.local for development, .env.prod for production
# NEVER commit real values to git
# =====================================================

# ── Application ──────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME_FA=پیش‌بینی جام جهانی ۲۰۲۶
NEXT_PUBLIC_APP_NAME_EN=WC 2026 Prediction

# ── Database (via PgBouncer in production) ───────────
DATABASE_URL=postgresql://football_user:password@localhost:5432/football_db
# Production: postgresql://football_user:password@pgbouncer:5432/football_db?pgbouncer=true&connection_limit=1

# ── Redis Sentinel ───────────────────────────────────
REDIS_SENTINEL_HOSTS=localhost:26379
# Production: redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
REDIS_SENTINEL_NAME=mymaster
REDIS_PASSWORD=

# ── JWT — RS256 Keys (generate with scripts/generate-keys.sh) ──
# Private key: PEM format (sign tokens — KEEP IN VAULT, not in .env in prod)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG...\n-----END PRIVATE KEY-----"
# Public key: PEM format (verify tokens — safe to store in app)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG...\n-----END PUBLIC KEY-----"

# ── Object Storage (Arvan Cloud or MinIO) ───────────
S3_ENDPOINT=https://s3.ir-thr-at1.arvanstorage.ir
S3_ENDPOINT_HOSTNAME=s3.ir-thr-at1.arvanstorage.ir
S3_REGION=ir-thr-at1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=football-assets
# Signed URL expiry in seconds (15 minutes)
S3_URL_EXPIRY=900

# ── National ID Encryption (AES-256-GCM) ────────────
# MUST be stored in Arvan Vault in production — 64 hex chars (32 bytes)
NATIONAL_ID_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f

# ── Kaveh Negar SMS ──────────────────────────────────
KAVEH_NEGAR_API_KEY=your-api-key-here
KAVEH_NEGAR_SENDER=your-sender-number
KAVEH_NEGAR_TEMPLATE_OTP=your-template-name
KAVEH_NEGAR_WEBHOOK_SECRET=your-webhook-hmac-secret

# ── Email (SMTP) ─────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp-password
SMTP_FROM="جام جهانی ۲۰۲۶ <noreply@example.com>"

# ── Cloudflare Turnstile ─────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxx

# ── BullMQ ───────────────────────────────────────────
# Uses same Redis connection above

# ── Rate Limiting ────────────────────────────────────
OTP_MAX_PER_MOBILE_PER_15MIN=5
OTP_LOCKOUT_MAX_FAILURES_PER_HOUR=5
OTP_LOCKOUT_DURATION_SECONDS=3600
OTP_SESSION_EXPIRY_SECONDS=120
OTP_MAX_ATTEMPTS_PER_SESSION=3

# ── Pagination ───────────────────────────────────────
RANKINGS_PAGE_SIZE=50
MATCHES_PAGE_SIZE=20

# ── Football Data API (football-data.org — free tier) ─
# Register at https://www.football-data.org/client/register
# Free tier includes WC 2026 results — 10 req/min
FOOTBALL_DATA_API_KEY=

# ── Feature Flags ────────────────────────────────────
MAINTENANCE_MODE=false
